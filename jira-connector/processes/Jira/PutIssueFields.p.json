{
  "$schema" : "https://json-schema.axonivy.com/process/12.0.0/process.json",
  "id" : "019D616705655FDC",
  "kind" : "CALLABLE_SUB",
  "config" : {
    "data" : "com.axonivy.connector.jira.IssueData"
  },
  "elements" : [ {
      "id" : "f0",
      "type" : "CallSubStart",
      "name" : "call(String,Map,Boolean)",
      "config" : {
        "signature" : "call",
        "input" : {
          "params" : [
            { "name" : "key", "type" : "String", "desc" : "key issue" },
            { "name" : "fields", "type" : "java.util.Map", "desc" : "" },
            { "name" : "notifyUsers", "type" : "Boolean", "desc" : "" }
          ],
          "map" : {
            "out.fields" : "param.fields",
            "out.issueKey" : "param.key",
            "out.notifyUsers" : "param.notifyUsers"
          }
        }
      },
      "visual" : {
        "at" : { "x" : 96, "y" : 64 }
      },
      "connect" : [
        { "id" : "f2", "to" : "f5" }
      ]
    }, {
      "id" : "f1",
      "type" : "CallSubEnd",
      "visual" : {
        "at" : { "x" : 560, "y" : 64 },
        "labelOffset" : { "x" : 13, "y" : 33 }
      }
    }, {
      "id" : "f3",
      "type" : "RestClientCall",
      "name" : "Put Issue Fields",
      "config" : {
        "method" : "PUT",
        "target" : {
          "clientId" : "a5b21baf-2b4f-44ac-a9e7-9c1b0607e0a6",
          "path" : "/issue/{issueKey}",
          "templateParams" : {
            "ivy.var.jira-connector.Url" : "",
            "issueKey" : "in.issueKey"
          },
          "queryParams" : {
            "notifyUsers" : "in.notifyUsers"
          }
        },
        "body" : {
          "type" : "RAW",
          "raw" : "<%=in.body %>"
        }
      },
      "visual" : {
        "at" : { "x" : 384, "y" : 64 }
      },
      "connect" : [
        { "id" : "f4", "to" : "f1", "color" : "default" }
      ]
    }, {
      "id" : "f5",
      "type" : "Script",
      "name" : "Prepare body",
      "config" : {
        "output" : {
          "code" : [
            "import com.axonivy.connector.jira.utils.IssueUtils;",
            "in.body = IssueUtils.prepareIssueFields(in.fields);"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 224, "y" : 64 }
      },
      "connect" : [
        { "id" : "f6", "to" : "f3", "color" : "default" }
      ]
    } ]
}