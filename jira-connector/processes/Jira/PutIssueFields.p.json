{
  "$schema" : "https://json-schema.axonivy.com/process/13.1.2/process.json",
  "id" : "019D616705655FDC",
  "kind" : "CALLABLE_SUB",
  "config" : {
    "data" : "com.axonivy.connector.jira.IssueData"
  },
  "elements" : [ {
      "id" : "f0",
      "type" : "CallSubStart",
      "name" : "call(String,Map,String)",
      "config" : {
        "signature" : "call",
        "input" : {
          "params" : [
            { "name" : "key", "type" : "String", "desc" : "key issue" },
            { "name" : "fields", "type" : "java.util.Map", "desc" : "" },
            { "name" : "params", "type" : "String", "desc" : "Path params" }
          ],
          "map" : {
            "out.fields" : "param.fields",
            "out.issueKey" : "param.key",
            "out.queryParams" : "param.params"
          }
        },
        "result" : {
          "params" : [
            { "name" : "error", "type" : "ch.ivyteam.ivy.bpm.error.BpmError", "desc" : "" }
          ],
          "map" : {
            "result.error" : "in.#error"
          }
        }
      },
      "visual" : {
        "at" : { "x" : 96, "y" : 64 }
      },
      "connect" : [
        { "id" : "f2", "to" : "f5" }
      ]
    }, {
      "id" : "f1",
      "type" : "CallSubEnd",
      "visual" : {
        "at" : { "x" : 560, "y" : 64 },
        "labelOffset" : { "x" : 13, "y" : 33 }
      }
    }, {
      "id" : "f3",
      "type" : "RestClientCall",
      "name" : "Put Issue Fields",
      "config" : {
        "method" : "PUT",
        "target" : {
          "clientId" : "a5b21baf-2b4f-44ac-a9e7-9c1b0607e0a6",
          "path" : "/issue/{issueKey}{queryParams}",
          "templateParams" : {
            "ivy.var.jiraConnector.Url" : "",
            "issueKey" : "in.issueKey",
            "queryParams" : "in.queryParams"
          }
        },
        "body" : {
          "type" : "RAW",
          "raw" : "<%=in.body %>"
        }
      },
      "visual" : {
        "at" : { "x" : 408, "y" : 64 }
      },
      "boundaries" : [ {
          "id" : "f7",
          "type" : "ErrorBoundaryEvent",
          "config" : {
            "output" : {
              "map" : {
                "out" : "in",
                "out.error" : "error"
              }
            }
          },
          "visual" : {
            "at" : { "x" : 440, "y" : 104 }
          },
          "connect" : [
            { "id" : "f8", "to" : "f1" }
          ]
        } ],
      "connect" : [
        { "id" : "f4", "to" : "f1", "color" : "default" }
      ]
    }, {
      "id" : "f5",
      "type" : "Script",
      "name" : "Prepare body",
      "config" : {
        "output" : {
          "code" : [
            "import com.axonivy.connector.jira.utils.JsonUtils;",
            "in.body = JsonUtils.convertMapToJsonString(in.fields);"
          ]
        }
      },
      "visual" : {
        "at" : { "x" : 248, "y" : 64 }
      },
      "connect" : [
        { "id" : "f6", "to" : "f3", "color" : "default" }
      ]
    } ]
}